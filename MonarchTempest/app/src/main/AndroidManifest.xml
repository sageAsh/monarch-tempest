<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--Use android:screenOrientation="landscape" to lock the device orientation.
    This is needed for Monarch Development.

    The android:name=".MonarchTempestApplication" is crucial for making the commands work. If that is not added the commands will not work.
    -->
    <application
        android:name=".MonarchTempestApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MonarchTempest"
        tools:targetApi="34"
        android:screenOrientation="landscape">

        <activity
            android:name=".activities.TitleScreenExampleActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat"/>

        <activity
            android:name=".activities.BrailleTranslatorActivity"
            android:exported="false"/>

        <activity
            android:name=".activities.DialogSampleActivity"
            android:exported="false"/>

        <activity
            android:name=".activities.SelfBraillingActivity"
            android:exported="false"/>

        <activity
            android:name=".contextmenu.SimpleContextMenuActivity"
            android:exported="false"/>

        <activity
            android:name=".contextmenu.SelfBraillingContextMenuActivity"
            android:exported="false"/>

        <!--SubMenus require launchMode and noHistory to be set-->
        <activity
            android:name=".contextmenu.HWDialogSubMenuActivity"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:exported="false"
            />

        <activity
            android:name=".contextmenu.HWDialogLongSMActivity"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:exported="false"
            />

        <activity
            android:name=".contextmenu.NativeDialogSubMenuActivity"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:exported="false"
            />

        <activity
            android:name=".contextmenu.NativeDialogLongSMActivity"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:exported="false"
            />

        <activity android:name=".activities.TextEditActivity"
            android:exported="false"/>

        <provider
            android:name="XmlResource"
            android:authorities="org.aph.monarchtempest.XmlResource"
            android:grantUriPermissions="true"
            android:exported="true">
        </provider>
    </application>
</manifest>
